  "keyFeatures": [
    "File-based routing with App Router and Pages Router",
    "React Server Components and Client Components",
    "Built-in image, font, and script optimization",
    "Hybrid static and server-side rendering (SSG, SSR, ISR)",
    "Turbopack bundler for fast builds and hot reloading",
    "Route handlers and API routes",
    "Streaming with React Suspense",
    "Middleware for edge computing",
    "Built-in CSS, Sass, and CSS-in-JS support",
    "TypeScript and ESLint integration out of the box",
    "Automatic code splitting and prefetching",
    "Internationalization support"
  ],
  "publicApiSurface": [
    "next/image — Image component with optimization",
    "next/link — Client-side navigation component",
    "next/script — Script loading component",
    "next/font — Font optimization API",
    "next/navigation — useRouter, usePathname, useSearchParams, useParams",
    "next/headers — cookies(), headers() server functions",
    "next/server — NextRequest, NextResponse, middleware utilities",
    "next/cache — revalidatePath(), revalidateTag(), unstable_cache()",
    "generateStaticParams() — Static route generation",
    "generateMetadata() — Dynamic metadata generation",
    "next.config.js — Framework configuration",
    "create-next-app — Project scaffolding CLI"
